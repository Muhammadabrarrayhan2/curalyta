# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://curalyta:curalyta@localhost:5432/curalyta?schema=public"

# ============================================================
# SERVER
# ============================================================
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ============================================================
# AUTH
# ============================================================
# Generate strong secrets for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-strong-secret-min-32-chars-for-production"
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ============================================================
# DEFAULT ADMIN (created by seed)
# ============================================================
ADMIN_EMAIL=admin@curalyta.app
ADMIN_PASSWORD=Curalyta#2025

# ============================================================
# ANTHROPIC AI (optional — platform runs fully without this)
# ============================================================
# If empty, AI features will be disabled gracefully.
# Get key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================================
# PUBLIC AI (optional - for Tanya AI without login)
# ============================================================
# Get key from: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-27b-it
GEMINI_VISION_MODEL=gemini-2.5-flash
PUBLIC_AI_IMAGE_MAX_MB=5

# ============================================================
# FILE UPLOADS
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
