# ============================================================
# Curalyta Docker Compose Environment
# Copy this file to .env and edit before running `docker-compose up`
# ============================================================

# --- Database ---
POSTGRES_USER=curalyta
POSTGRES_PASSWORD=curalyta_dev_pw
POSTGRES_DB=curalyta
POSTGRES_PORT=5432

# --- Ports ---
BACKEND_PORT=4000
FRONTEND_PORT=8080

# --- Security (CHANGE FOR PRODUCTION) ---
# Generate strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# --- Default admin ---
ADMIN_EMAIL=admin@curalyta.app
ADMIN_PASSWORD=Curalyta#2025

# --- CORS ---
# Should match the URL where frontend is accessed
CORS_ORIGIN=http://localhost:8080

# --- Anthropic AI (optional — leave empty to disable AI features) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Public AI / Gemini (optional - for Tanya AI tanpa login) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-27b-it

# --- Upload limits ---
MAX_FILE_SIZE_MB=10

# --- Rate limits ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
